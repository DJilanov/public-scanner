NODE_ENV=production
PUBLIC_SCANNER_HOME=/opt/public-scanner
API_HOST=127.0.0.1
API_PORT=3201
DATABASE_URL=postgresql://postgres:replace-with-password@127.0.0.1:5432/public_scanner_dev
SESSION_TTL_DAYS=14
WORKER_MODE=scheduler
WORKER_INTERVAL_MINUTES=360
BACKFILL_DAYS=3
TED_MAX_PAGES=20
AI_ANALYSIS_ENABLED=true
AI_ANALYSIS_AUTO_ENABLED=false
AI_ANALYSIS_MAX_PER_RUN=25
AI_ANALYSIS_MIN_SCORE=62
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MAX_TOKENS=1800
